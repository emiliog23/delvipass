{
  "expo": {
    "name": "Boletero",
    "slug": "boletero",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "boletero",
    "splash": {
      "backgroundColor": "#667eea"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#667eea"
      },
      "permissions": ["android.permission.CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Necesitamos acceso a la cámara para escanear los códigos QR de los invitados."
        }
      ]
    ]
  }
}
